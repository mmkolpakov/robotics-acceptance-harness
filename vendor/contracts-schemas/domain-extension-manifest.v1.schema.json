{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmkolpakov.github.io/robotics-runtime-contracts/schemas/domain-extension-manifest.v1.schema.json",
  "title": "DomainExtensionManifestV1",
  "type": "object",
  "required": [
    "schema_version",
    "extension_id",
    "status",
    "extends",
    "compatibility_tests"
  ],
  "properties": {
    "schema_version": { "const": "domain-extension-manifest.v1" },
    "extension_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "status": {
      "type": "string",
      "enum": ["local", "proposed", "accepted"]
    },
    "extends": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "compatibility_tests": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "promotion_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "adr": { "type": "string" },
    "architecture_approval": {
      "type": "object",
      "required": ["required", "status"],
      "properties": {
        "required": { "const": true },
        "status": {
          "type": "string",
          "enum": ["pending", "approved"]
        },
        "approver": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

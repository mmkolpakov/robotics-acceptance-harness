{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmkolpakov.github.io/robotics-runtime-contracts/schemas/run-metrics.v1.schema.json",
  "title": "RunMetricsV1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "metrics"
  ],
  "properties": {
    "schema_version": { "const": "run-metrics.v1" },
    "run_id": { "type": "string" },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "value"],
        "properties": {
          "name": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["counter", "gauge", "duration", "ratio", "label"]
          },
          "value": {
            "type": ["number", "integer", "string", "boolean"]
          },
          "unit": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

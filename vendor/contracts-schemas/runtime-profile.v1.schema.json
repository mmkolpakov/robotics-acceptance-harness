{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmkolpakov.github.io/robotics-runtime-contracts/schemas/runtime-profile.v1.schema.json",
  "title": "RuntimeProfileV1",
  "type": "object",
  "required": [
    "schema_version",
    "profile_id",
    "target_environment",
    "capabilities",
    "execution_guard"
  ],
  "properties": {
    "schema_version": { "const": "runtime-profile.v1" },
    "profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "target_environment": {
      "type": "string",
      "enum": ["simulation", "hil", "real_robot"]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ros2",
          "gazebo",
          "mavlink",
          "mavros",
          "ros2_control",
          "moveit2",
          "rosbag2_mcap",
          "perception_runtime",
          "artifact_store"
        ]
      },
      "uniqueItems": true
    },
    "gpu": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": { "type": "boolean" },
        "provider": {
          "type": "string",
          "enum": ["none", "nvidia", "intel", "amd", "external"]
        }
      },
      "additionalProperties": false
    },
    "execution_guard": {
      "type": "object",
      "required": ["allow_physical_actuation"],
      "properties": {
        "allow_physical_actuation": { "type": "boolean" },
        "required_confirmation_env": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

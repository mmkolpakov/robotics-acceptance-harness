{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmkolpakov.github.io/robotics-runtime-contracts/schemas/scenario-manifest.v1.schema.json",
  "title": "ScenarioManifestV1",
  "type": "object",
  "required": [
    "schema_version",
    "scenario_id",
    "target_environment",
    "launch",
    "simulation",
    "expected_ros_graph",
    "recording",
    "safety"
  ],
  "properties": {
    "schema_version": { "const": "scenario-manifest.v1" },
    "scenario_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "title": { "type": "string" },
    "target_environment": {
      "type": "string",
      "enum": ["simulation", "hil", "real_robot"]
    },
    "launch": {
      "type": "object",
      "required": ["entrypoint", "package"],
      "properties": {
        "entrypoint": {
          "type": "string",
          "enum": ["ros2_launch", "docker_compose", "external_command"]
        },
        "package": { "type": "string" },
        "file": { "type": "string" },
        "arguments": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "simulation": {
      "type": "object",
      "required": ["duration_sec", "wall_timeout_sec", "headless"],
      "properties": {
        "duration_sec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400
        },
        "wall_timeout_sec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 172800
        },
        "headless": { "type": "boolean" },
        "physics_engine": { "type": "string" }
      },
      "additionalProperties": false
    },
    "expected_ros_graph": {
      "$ref": "ros-graph-contract.v1.schema.json"
    },
    "recording": {
      "type": "object",
      "required": ["enabled", "storage", "topics", "image_transport", "retention"],
      "properties": {
        "enabled": { "type": "boolean" },
        "storage": {
          "type": "string",
          "enum": ["mcap", "sqlite3"]
        },
        "topics": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "image_transport": {
          "type": "object",
          "required": ["policy"],
          "properties": {
            "policy": {
              "type": "string",
              "enum": ["raw", "compressed", "on_failure_only"]
            }
          },
          "additionalProperties": false
        },
        "retention": {
          "$ref": "artifact-store-policy.v1.schema.json#/definitions/retention"
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": ["execution_guard"],
      "properties": {
        "execution_guard": {
          "type": "object",
          "required": ["allow_physical_actuation"],
          "properties": {
            "allow_physical_actuation": { "type": "boolean" },
            "required_confirmation_env": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "target_environment": {
            "enum": ["hil", "real_robot"]
          }
        }
      },
      "then": {
        "properties": {
          "safety": {
            "properties": {
              "execution_guard": {
                "required": ["required_confirmation_env"]
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmkolpakov.github.io/robotics-runtime-contracts/schemas/model-artifact.v1.schema.json",
  "title": "ModelArtifactV1",
  "type": "object",
  "required": [
    "schema_version",
    "model_id",
    "format",
    "runtime",
    "artifact"
  ],
  "properties": {
    "schema_version": { "const": "model-artifact.v1" },
    "model_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "format": {
      "type": "string",
      "enum": ["onnx", "torchscript", "tensorrt", "openvino", "other"]
    },
    "runtime": {
      "type": "object",
      "required": ["provider", "version"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["onnxruntime", "pytorch", "tensorrt", "openvino", "external"]
        },
        "version": { "type": "string" },
        "requires_gpu": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["uri", "sha256"],
      "properties": {
        "uri": { "type": "string" },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

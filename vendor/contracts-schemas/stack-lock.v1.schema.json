{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmkolpakov.github.io/robotics-runtime-contracts/schemas/stack-lock.v1.schema.json",
  "title": "StackLockV1",
  "type": "object",
  "required": [
    "schema_version",
    "lock_id",
    "repositories",
    "images"
  ],
  "properties": {
    "schema_version": { "const": "stack-lock.v1" },
    "lock_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "repositories": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["url", "ref", "commit"],
        "properties": {
          "url": { "type": "string", "minLength": 1 },
          "ref": { "type": "string", "minLength": 1 },
          "commit": {
            "type": "string",
            "pattern": "^[a-f0-9]{40}$"
          }
        },
        "additionalProperties": false
      }
    },
    "images": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["ref", "digest"],
        "properties": {
          "ref": { "type": "string", "minLength": 1 },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

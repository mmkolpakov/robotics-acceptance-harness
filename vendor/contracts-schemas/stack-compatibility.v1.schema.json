{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmkolpakov.github.io/robotics-runtime-contracts/schemas/stack-compatibility.v1.schema.json",
  "title": "StackCompatibilityV1",
  "type": "object",
  "required": [
    "schema_version",
    "compatibility_id",
    "requires",
    "gates"
  ],
  "properties": {
    "schema_version": { "const": "stack-compatibility.v1" },
    "compatibility_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "requires": {
      "type": "object",
      "required": ["infra_release", "contracts", "harness"],
      "properties": {
        "infra_release": { "type": "string", "minLength": 1 },
        "contracts": { "type": "string", "minLength": 1 },
        "harness": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "required", "command", "expected_artifact", "required_result"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "command": { "type": "string", "minLength": 1 },
          "expected_artifact": { "type": "string", "minLength": 1 },
          "required_result": {
            "type": "string",
            "enum": ["pass", "executed"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
